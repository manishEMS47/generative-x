OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Text-to-speech provider: "elevenlabs" (default) or "60db".
# Can be overridden per request via the `provider` field in /api/speech.
TTS_PROVIDER=elevenlabs

# 60db (https://60db.ai) credentials — only needed when TTS_PROVIDER=60db
SIXTYDB_API_KEY=
# Default 60db voice UUID. List yours at GET https://api.60db.ai/myvoices.
# If left blank, 60db uses its system default voice.
SIXTYDB_DEFAULT_VOICE_ID=
